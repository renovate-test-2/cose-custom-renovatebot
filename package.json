{
  "name": "@mattrglobal/cose",
  "version": "1.0.1",
  "author": "MATTR",
  "license": "SEE LICENCE IN https://learn.mattr.global/docs/terms/sdk-licence-verifier-single-format-cwt-cose/",
  "private": false,
  "description": "An implementation of RFC8152",
  "homepage": "https://github.com/mattrglobal/cose",
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "repository": "https://github.com/mattrglobal/cose",
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib"
  ],
  "engines": {
    "node": ">=10.0.0"
  },
  "scripts": {
    "build": "tsc --pretty",
    "format": "prettier --write \"**/*.ts\" \"**/*.md\"  \"!**/lib/**\"",
    "lint": "eslint . --ext .ts --color --format=table",
    "lint:fix": "yarn lint --fix",
    "test": "jest"
  },
  "devDependencies": {
    "@commitlint/cli": "17.4.4",
    "@commitlint/config-conventional": "17.4.4",
    "@stablelib/hex": "1.0.1",
    "@types/jest": "^29.0.0",
    "@types/node": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "5.55.0",
    "@typescript-eslint/parser": "5.55.0",
    "conventional-changelog": "3.1.25",
    "conventional-changelog-cli": "2.2.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "8.36.0",
    "eslint-config-prettier": "^8.0.0",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "husky": "8.0.3",
    "jest": "29.5.0",
    "prettier": "2.8.4",
    "pretty-quick": "3.1.3",
    "text-encoding": "0.7.0",
    "ts-jest": "29.0.5",
    "ts-node": "10.9.1",
    "typescript": "4.9.5"
  },
  "dependencies": {
    "@cto.af/textdecoder": "0.2.0",
    "@peculiar/webcrypto": "1.4.1",
    "@stablelib/base64": "1.0.1",
    "bignumber.js": "9.1.1",
    "buffer": "6.0.3",
    "cbor": "8.1.0",
    "cbor-web": "8.1.0",
    "util": "0.12.5",
    "zod": "3.21.4"
  },
  "react-native": {
    "./lib/crypto/crypto.js": "./lib/crypto/crypto-rn.js"
  },
  "browser": {
    "./lib/cbor/cbor.js": "./lib/cbor/cbor-browser.js",
    "./lib/crypto/crypto.js": "./lib/crypto/crypto-browser.js"
  },
  "husky": {
    "hooks": {
      "commit-msg": "[[ -n $HUSKY_BYPASS ]] || commitlint -E HUSKY_GIT_PARAMS",
      "pre-commit": "[[ -n $HUSKY_BYPASS ]] || pretty-quick --staged"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
